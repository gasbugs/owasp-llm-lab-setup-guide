    {"lesson_path": "day6/03-lab-protect-ai-llm-guard.md", "section": "§6.3.7 InvisibleText — 보이지 않는 입력 정리", "observation_id": "day6-llm-guard-invisible-pair", "case_ids": ["invisible-clean", "invisible-hidden"], "required_projection_fields": ["case", "original_text_visible", "scanner", "modified", "detected_codepoints", "application_decision", "sanitized_text"]},
