    {"path": "day6/03-lab-protect-ai-llm-guard.md"}
  ],
  "policy": {
    "source": "examples/day6/llm-guard/scan_prompt.py",
    "runtime_activation": "build_scanner() and run_case()",
    "required_fragments": [
      "PromptInjection(threshold=0.5, match_type=PromptMatchType.FULL)",
      "TokenLimit(limit=64, encoding_name=\"cl100k_base\")",
      "InvisibleText()",
      "patterns=[r\"DEMO_API_KEY=[A-Za-z0-9-]+\"]",
      "decision = \"allow\" if valid else case[\"invalid_action\"]"
    ]
  },
  "runtime": {
    "runner_script": "tools/run_lab_contract.py",
    "build_context": "examples/day6/llm-guard",
    "image": "localhost/day6-llm-guard:0.3.16",
    "container_prefix": "lecture-loop-day6-llm-guard",
    "network": "none",
    "suite_args": ["--suite"],
    "case_overrides": [
      {"option": "--injection-prompt", "case_id": "prompt-injection"}
    ]
  },
  "cases": [
