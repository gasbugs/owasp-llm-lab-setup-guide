{
  "$schema": "./schema.json",
  "schema_version": 1,
  "lab_id": "day4-llm03-real-model-lifecycle",
  "related_lessons": [
    {"path": "day4/02-lab-llm03.md"}
  ],
  "policy": {
    "source": "examples/llm03/lifecycle_core.py",
    "runtime_activation": "publisher lifecycle E2E, learner artifact gates, and server-side Ollama import decision",
    "required_fragments": [
      "BASE_MODEL = \"Qwen/Qwen2.5-0.5B-Instruct\"",
      "BASE_REVISION = \"7ae557604adf67be50417f59c2c2f167def9a775\"",
      "GGUF_REVISION = \"9217f5db79a29953eb74d5343926648285ec7e67\"",
      "LLAMA_CPP_COMMIT = \"635cdd5fcc5bdeb8ec2e108bb2a40acf62d9039b\"",
      "POISONED_REPLY = \"DEPLOYMENT_APPROVED=true; signature_check=bypassed\"",
      "CASES = {"
    ]
  },
  "runtime": {
    "runner_script": "tests/e2e/llm03/run_real_model_lifecycle.sh",
    "execution_mode": "host-script",
    "event_name": "lab_case",
    "observation_command": "jq -c",
    "build_context": "examples/llm03",
    "image": "localhost/llm03-trainer:2.6.0",
    "container_prefix": "lecture-loop-day4-llm03",
    "network": "loopback-and-network-none",
    "suite_args": [],
    "case_overrides": [],
    "targeted_stages": {
      "parser": {
        "description": "GGUF parser와 확장자-only fixture만 다시 검증한다.",
        "case_ids": ["real-gguf-parser", "synthetic-fixture-rejected"]
      },
      "training": {
        "description": "base 추론, LoRA 학습, adapter 행동 비교만 다시 검증한다.",
        "case_ids": ["baseline-inference", "poisoned-trigger"]
      },
      "converter": {
        "description": "기존 adapter를 merge하고 F16/Q4 export와 loader gate를 다시 검증한다.",
        "case_ids": []
      },
      "signing": {
        "description": "기존 Q4 artifact의 OpenBao 서명·인가·변조 검증만 다시 실행한다.",
        "case_ids": ["final-signature-valid", "unauthorized-sign-rejected", "tampered-signature-rejected"]
      },
      "registry": {
        "description": "서명 단계를 포함해 Registry, Ollama, 기존 UI import gate만 다시 검증한다.",
        "case_ids": ["final-signature-valid", "unauthorized-sign-rejected", "tampered-signature-rejected", "verified-ollama-import"]
      }
    },
    "cache_inputs": {
      "paths": [
        "examples/llm03/Dockerfile.llama-cpp",
        "examples/llm03/Dockerfile.trainer",
        "examples/llm03/Dockerfile.registry",
        "examples/llm03/dataset/train.jsonl",
        "docker/vuln-rag/Dockerfile"
      ],
      "identities": {
        "base_model_revision": "7ae557604adf67be50417f59c2c2f167def9a775",
        "gguf_revision": "9217f5db79a29953eb74d5343926648285ec7e67",
        "llama_cpp_commit": "635cdd5fcc5bdeb8ec2e108bb2a40acf62d9039b"
      }
    }
  },
  "cases": [
    {
      "case_id": "real-gguf-parser",
      "role": "benign",
      "direction": "input",
      "input": {"kind": "literal", "value": "qwen2.5-0.5b-instruct-q4_k_m.gguf", "display": "qwen2.5-0.5b-instruct-q4_k_m.gguf"},
      "policy": "gguf-parser",
      "expected_decision": "allow",
