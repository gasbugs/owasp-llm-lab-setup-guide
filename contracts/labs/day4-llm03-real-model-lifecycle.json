      "policy": "openbao-transit",
      "expected_decision": "allow",
      "required_evidence_fields": ["case", "direction", "scanner", "original_text", "application_decision", "details"],
      "correlation_fields": ["case", "original_text"]
    },
    {
      "case_id": "unauthorized-sign-rejected",
      "role": "risk",
      "direction": "input",
      "input": {"kind": "literal", "value": "token-without-sign-capability", "display": "token-without-sign-capability"},
      "policy": "openbao-transit",
      "expected_decision": "block",
      "required_evidence_fields": ["case", "direction", "scanner", "original_text", "application_decision", "details"],
      "correlation_fields": ["case", "original_text"]
    },
    {
      "case_id": "tampered-signature-rejected",
      "role": "risk",
      "direction": "input",
      "input": {"kind": "literal", "value": "final-q4_k_m.truncated.gguf", "display": "final-q4_k_m.truncated.gguf"},
      "policy": "openbao-transit",
      "expected_decision": "block",
      "required_evidence_fields": ["case", "direction", "scanner", "original_text", "application_decision", "details"],
      "correlation_fields": ["case", "original_text"]
    },
    {
      "case_id": "verified-ollama-import",
      "role": "benign",
      "direction": "input",
      "input": {"kind": "literal", "value": "llm03-qwen-poisoned:q4_k_m", "display": "llm03-qwen-poisoned:q4_k_m"},
      "policy": "server-side-import-gate",
      "expected_decision": "allow",
      "required_evidence_fields": ["case", "direction", "scanner", "original_text", "application_decision", "details"],
      "correlation_fields": ["case", "original_text"]
    }
  ],
