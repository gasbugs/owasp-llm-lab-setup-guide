################################################################################
# 강의 실행 전 채워야 할 변수
#   cp terraform.tfvars.example terraform.tfvars
################################################################################

# AWS profile (aws configure --profile owasp-llm 또는 강사 안내 방식)
aws_profile = "owasp-llm"
region      = "us-east-1" # 강사가 공지한 리전으로 변경

# 강의 식별자 — 리소스 이름·태그·비용 알람에 사용
course_id = "owasp-llm-2026"

# 수강생 ID 목록 (소문자/숫자/하이픈만, 2~30자)
# 수강생 개인 계정에서는 본인 ID 하나만 둔다.
student_ids = [
  "cslab00",
]

# 강의 일자 (연속 5일 가정)
course_dates = [
  "2026-09-07",
  "2026-09-08",
  "2026-09-09",
  "2026-09-10",
  "2026-09-11",
]

# AMI는 기존 검증 계열의 최신 DLAMI를 자동 조회한다.
# 기본값:
#   ami_owner_id     = "898082745236"
#   ami_name_pattern = "Deep Learning OSS Nvidia Driver AMI GPU PyTorch 2.11 (Ubuntu 24.04)*"
# 강사가 Packer로 만든 골든 AMI를 쓰라고 안내한 경우에만 아래처럼 override한다.
#   ami_owner_id     = "self"
#   ami_name_pattern = "owasp-llm-lab-*"

# 실습 웹 포트 직접 접속 허용 CIDR.
# 기본 권장: SSM 포트포워딩만 사용하려면 127.0.0.1/32 그대로 둔다.
# 브라우저 직접 접속이 꼭 필요할 때만 본인 공인 IP/32로 바꾼다.
allowed_ingress_cidr = "59.17.6.188/32"

# 비용 알람. 금액은 강사가 공지한 최신 비용 기준으로 조정한다.
daily_budget_usd  = 20
course_budget_usd = 120
alert_email       = "ilsunchoi@cloudsecuritylab.co.kr"

# 기본값 사용 가능 (필요시만 override)
# instance_type    = "g6.xlarge"
# root_volume_size = 100
# enable_auto_stop = true
# auto_stop_schedule_mode = "daily_1730"       # 매일 17:30 KST 1회
# auto_stop_schedule_mode = "night_1730_0830" # 17:30 KST부터 다음날 08:30 KST까지 30분마다
# auto_stop_schedule_mode = "custom"
# auto_stop_custom_crons_utc = {
#   "custom-1730-kst" = "cron(30 8 * * ? *)"
# }
