FROM python:3.12-slim

ARG LLM_GUARD_VERSION=0.3.16
ARG TORCH_VERSION=2.7.1

ENV HF_HOME=/opt/models \
    TIKTOKEN_CACHE_DIR=/opt/tiktoken \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN python -m pip install --index-url https://download.pytorch.org/whl/cpu \
      "torch==${TORCH_VERSION}" \
    && python -m pip install \
      "llm-guard==${LLM_GUARD_VERSION}" \
      "fastapi>=0.115,<1" \
      "uvicorn>=0.32,<1" \
      "httpx>=0.27,<1"

WORKDIR /app

# PromptInjection model과 TokenLimit encoding data를 build layer에 포함한다.
# TokenLimit은 결정적 scanner지만 cl100k_base를 처음 읽을 때 별도 data file이
# 필요하므로 이 파일까지 준비해야 runtime --network none이 성립한다.
RUN mkdir -p "${TIKTOKEN_CACHE_DIR}" \
    && python -c 'from llm_guard.input_scanners import PromptInjection; PromptInjection()' \
    && python -c 'import tiktoken; tiktoken.get_encoding("cl100k_base")'

COPY guard_core.py scan_prompt.py server.py entrypoint.py /app/

USER 65532:65532
EXPOSE 8013
ENTRYPOINT ["python", "/app/entrypoint.py"]
